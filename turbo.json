{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local", "pnpm-lock.yaml"],
  "globalEnv": ["NODE_ENV", "VERCEL_ENV", "VERCEL_URL", "CI", "GITHUB_ACTIONS"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", ".turbo/**"],
      "inputs": ["src/**", "public/**", "package.json"]
    },
    "lint": {
      "outputs": [],
      "inputs": ["src/**", "*.config.*", "package.json"]
    },
    "lint:biome": {
      "outputs": [],
      "inputs": ["src/**", "*.config.*", "package.json"]
    },
    "lint:biome:fix": {
      "outputs": [],
      "inputs": ["src/**", "*.config.*", "package.json"]
    },
    "typecheck": {
      "outputs": ["*.tsbuildinfo"],
      "inputs": ["src/**", "*.ts", "*.tsx", "package.json", "tsconfig.json"]
    },
    "format": {
      "outputs": [],
      "inputs": ["src/**", "*.config.*", "package.json"]
    },
    "format:check": {
      "outputs": [],
      "inputs": ["src/**", "*.config.*", "package.json"]
    },
    "check": {
      "outputs": [],
      "inputs": ["src/**", "*.config.*", "package.json"]
    },
    "check:fix": {
      "outputs": [],
      "inputs": ["src/**", "*.config.*", "package.json"]
    },
    "syncpack:lint": {
      "outputs": [],
      "inputs": ["package.json", "pnpm-workspace.yaml"]
    },
    "syncpack:fix": {
      "outputs": [],
      "inputs": ["package.json", "pnpm-workspace.yaml"]
    },
    "test": {
      "dependsOn": ["^build", "@agency/vitest-config#build"],
      "outputs": ["coverage/**", ".vitest-results/**"],
      "env": ["VITEST_POOL", "CI", "GITHUB_ACTIONS"],
      "inputs": ["src/**", "test/**", "*.test.*", "package.json"]
    },
    "test:watch": {
      "dependsOn": ["@agency/vitest-config#build"],
      "cache": false,
      "persistent": true,
      "inputs": ["src/**", "test/**", "*.test.*", "package.json"]
    },
    "test:ui": {
      "dependsOn": ["@agency/vitest-config#build"],
      "cache": false,
      "persistent": true,
      "inputs": ["src/**", "test/**", "*.test.*", "package.json"]
    },
    "test:bench": {
      "dependsOn": ["@agency/vitest-config#build"],
      "cache": false,
      "outputs": [".vitest-results/bench.json"],
      "inputs": ["src/**", "bench/**", "*.bench.*", "package.json"]
    },
    "test:coverage": {
      "dependsOn": ["^build", "@agency/vitest-config#build"],
      "outputs": ["coverage/**", ".vitest-results/**"],
      "env": ["VITEST_POOL", "CI", "GITHUB_ACTIONS"],
      "inputs": ["src/**", "test/**", "*.test.*", "package.json"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "inputs": ["src/**", "public/**", "package.json"]
    },
    "clean": {
      "cache": false,
      "outputs": ["dist/**", ".next/**", "coverage/**", ".vitest-results/**", "*.tsbuildinfo"]
    }
  }
}
